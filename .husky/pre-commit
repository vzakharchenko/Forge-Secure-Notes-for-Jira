#!/bin/sh
set -e
echo '➡️ <--- BUILD BACKEND --->'
echo '🔍 Running resolver checks...'

echo '➡️ lint-staged (resolver)'
npx lint-staged || { echo '❌ lint-staged failed for resolver'; exit 1; }

echo '➡️ typecheck (resolver)'
npm run build:ci || { echo '❌ build:ci failed'; exit 1; }

echo '➡️ dependencies check'
npm run knip || { echo '❌ Dependency check failed.'; exit 1; }

echo '➡️ lint check'
npm run lint || { echo '❌ lint check failed.'; exit 1; }
echo '➡️ lint check'
npm run test || { echo '❌ tests failed.'; exit 1; }
echo '➡️ <--- BUILD FRONTEND --->'
echo '🔍 Running static resources checks...'
cd static

echo '➡️ lint-staged (static resources)'
npx lint-staged || { echo '❌ lint-staged failed for static resources'; cd ..; exit 1; }


echo '➡️ dependencies check'
npm run knip || { echo '❌ Dependency check for static resources failed.'; cd ..; exit 1; }

echo '➡️ build'
npm run build || { echo '❌ Build failed'; cd ..; exit 1; }

echo '➡️ lint check'
npm run lint || { echo '❌ lint check failed.'; exit 1; }

cd ..
echo '➡️ <--- BUILD SITE --->'
cd web-site

echo '➡️ lint-staged (static resources)'
npx lint-staged || { echo '❌ lint-staged failed for static resources'; cd ..; exit 1; }


echo '➡️ dependencies check'
npm run knip || { echo '❌ Dependency check for static resources failed.'; exit 1; }

echo '➡️ build'
npm run build || { echo '❌ Build failed'; cd ..; exit 1; }

echo '➡️ lint check'
npm run lint || { echo '❌ lint check failed.'; exit 1; }

cd ..