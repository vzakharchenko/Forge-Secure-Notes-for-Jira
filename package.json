{
  "name": "jira-global-page-custom-ui",
  "version": "1.1.4",
  "main": "index.js",
  "license": "BUSL-1.1",
  "private": true,
  "dependencies": {
    "@forge/api": "^7.1.1",
    "@forge/events": "^2.1.1",
    "@forge/kvs": "^1.5.0",
    "@forge/realtime": "^0.3.2",
    "@forge/resolver": "1.7.1",
    "@forge/sql": "^3.0.20",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.1",
    "forge-sql-orm": "^2.1.25",
    "inversify": "^7.11.0",
    "luxon": "^3.7.2",
    "uuid": "^13.0.0"
  },
  "scripts": {
    "models:create": "forge-sql-orm-cli generate:model --output src/database/entities",
    "migration:create": "forge-sql-orm-cli migrations:create --force",
    "migration:update": "forge-sql-orm-cli migrations:update",
    "migration:drop": "forge-sql-orm-cli migrations:drop",
    "build:ci": "tsc --target esnext --project tsconfig.json  --outDir dist && rm -rf dist",
    "forge:debug": "forge tunnel -d -f index.handler",
    "lint": "eslint src __tests__ --ext .ts,.tsx",
    "lint:fix": "eslint src __tests__ --ext .ts,.tsx --fix",
    "format": "prettier --write src static/src shared __tests__ web-site ",
    "format:check": "prettier src static/src shared __tests__ web-site --check",
    "prepare": "husky",
    "knip": "knip",
    "test": "vitest --run --config vitest.config.mjs",
    "test:coverage": "vitest --run --config vitest.config.mjs --coverage",
    "test:watch": "vitest --watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vitest": "^0.5.4",
    "forge-sql-orm-cli": "^2.1.25",
    "husky": "^9.1.7",
    "knip": "^6.0.5",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "package-json": "npm:package-json@latest",
    "esbuild": "npm:esbuild@latest",
    "parse-url": "npm:parsed-url@latest",
    "gry": "npm:gry@latest",
    "rollup": "npm:rollup@4.59.0",
    "minimatch": "npm:minimatch@latest",
    "ajv": "npm:ajv@6.14.0"
  },
  "lint-staged": {
    "*.{ts,tsx,css,scss,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "cd .husky && ./pre-commit"
    }
  }
}
